rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isSupervisorOrAnalyst() {
      return hasRole('supervisor') || hasRole('analyst');
    }

    // Users Collection
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Sites Collection
    match /sites/{siteId} {
      allow read: if isAuthenticated();
      allow write: if isSupervisorOrAnalyst();
    }

    // Readings Collection
    match /readings/{readingId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated()
        && request.resource.data.status == 'pending'
        && (!('manualLevel' in request.resource.data) || request.resource.data.manualLevel == null || request.resource.data.manualLevel >= 0)
        && (!('aiDetectedLevel' in request.resource.data) || request.resource.data.aiDetectedLevel == null || request.resource.data.aiDetectedLevel >= 0)
        && (
          // Field officers (and citizens, via their own report submissions)
          // create readings for themselves.
          request.resource.data.submittedBy == request.auth.uid
          ||
          // Supervisors/analysts create a reading with submittedBy set to
          // the original citizen reporter's uid when verifying a citizen
          // report (see citizen_reports below) — submittedBy legitimately
          // differs from the writer's own uid in that one case.
          isSupervisorOrAnalyst()
        );

      allow update: if isAuthenticated()
        && (
          // Field officers can update their own pending readings
          (request.auth.uid == resource.data.submittedBy && resource.data.status == 'pending' && request.resource.data.status == 'pending')
          ||
          // Supervisors and Analysts can approve/reject and add notes
          (isSupervisorOrAnalyst() 
            && request.resource.data.submittedBy == resource.data.submittedBy
            && request.resource.data.manualLevel == resource.data.manualLevel
            && request.resource.data.aiDetectedLevel == resource.data.aiDetectedLevel)
        );

      allow delete: if isSupervisorOrAnalyst();
    }

    // Weather Data Collection
    match /weather_data/{weatherId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Citizen Reports Collection
    match /citizen_reports/{reportId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.verificationStatus == 'pending';

      // Analysts verify/flag/reject reports (citizen_reports_screen.dart);
      // supervisors get the same access as everywhere else in these rules.
      allow update: if isSupervisorOrAnalyst();

      allow delete: if isSupervisorOrAnalyst();
    }

    // Cascade Warnings Collection
    match /cascade_warnings/{siteId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
